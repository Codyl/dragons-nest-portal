{
  "name": "tanstack-router",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start:dev": "vp dev --mode development",
    "start:prod": "vp dev --mode production",
    "start:test": "vp dev --mode test",
    "build": "tsc -b && vp build",
    "lint": "vp lint .",
    "preview": "vp preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "vp fmt \"src/**/*.{ts,tsx}\"",
    "lint:fix": "vp lint \"src/**/*.{ts,tsx}\" --fix",
    "test:watch": "vp test watch",
    "test:coverage": "vp test run --coverage",
    "cypress:open:c": "cypress open --component",
    "cypress:run:c": "cypress run --component",
    "cypress:run:e2e": "start-server-and-test start:test http://localhost:5173 'cypress run --e2e --config-file cypress.config.mjs'",
    "cypress:open:e2e": "start-server-and-test start:test http://localhost:5173 'cypress open --e2e --config-file cypress.config.mjs'",
    "pre-commit": "vp staged",
    "prepare": "vp config"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
